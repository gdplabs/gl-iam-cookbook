# AIP Database (existing)
AIP_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aip

# GL-IAM Configuration
GLIAM_SECRET_KEY=your-secret-key-min-32-characters
GLIAM_ORGANIZATION_ID=aip-default-org
GLIAM_ENABLE_AUTH_HOSTING=true
GLIAM_AUTO_CREATE_TABLES=true

# Existing AIP API Keys (backward compatibility)
AIP_MASTER_API_KEY=your-master-api-key
