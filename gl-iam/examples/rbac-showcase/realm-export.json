{
  "id": "gl-iam-demo",
  "realm": "gl-iam-demo",
  "displayName": "GL-IAM RBAC Demo",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "id": "role-admin",
        "name": "admin",
        "description": "Organization administrator role (maps to ORG_ADMIN)"
      },
      {
        "id": "role-member",
        "name": "member",
        "description": "Standard member role (maps to ORG_MEMBER)"
      },
      {
        "id": "role-viewer",
        "name": "viewer",
        "description": "Read-only viewer role (maps to ORG_MEMBER)"
      }
    ]
  },
  "clients": [
    {
      "clientId": "glchat-backend",
      "name": "GLChat Backend",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "glchat-backend-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["profile", "roles", "email"],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Organization",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "member@example.com",
      "email": "member@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Regular",
      "lastName": "Member",
      "credentials": [
        {
          "type": "password",
          "value": "member123",
          "temporary": false
        }
      ],
      "realmRoles": ["member"]
    },
    {
      "username": "viewer@example.com",
      "email": "viewer@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ],
  "accessTokenLifespan": 3600
}
