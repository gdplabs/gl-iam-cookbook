# Database (shared by all 3 services — agent lookup only, tokens are stateless JWT)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gliam

# Shared secret key (used by all 3 services to sign/verify delegation JWTs)
SECRET_KEY=your-secret-key-min-32-characters-long

# Organization
DEFAULT_ORGANIZATION_ID=org-123

# Service URLs (each service knows where to forward requests)
AIP_BACKEND_URL=http://localhost:8001
CONNECTORS_URL=http://localhost:8002
