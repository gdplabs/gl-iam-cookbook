{
  "id": "dpop-lab",
  "realm": "dpop-lab",
  "displayName": "DPoP Lab",
  "enabled": true,
  "clients": [
    {
      "clientId": "lab-client",
      "name": "Lab Client",
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "lab-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret"
    }
  ],
  "users": [
    {
      "username": "lab-user",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "lab-pass",
          "temporary": false
        }
      ]
    }
  ]
}
