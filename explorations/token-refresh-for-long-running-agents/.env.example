# TokenManager Exploration - Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# Mock Settings (for demo purposes)
# ============================================================================

# Simulated token TTL in seconds (default: 60s for quick demo)
# In production, tokens typically last 1-24 hours
MOCK_TOKEN_TTL_SECONDS=60

# Organization ID for multi-tenancy context
ORGANIZATION_ID=org-demo-123

# ============================================================================
# Demo Behavior Settings
# ============================================================================

# Enable verbose logging to see token refresh events
VERBOSE_LOGGING=true

# Simulated API endpoint (for demo visualization)
MOCK_API_ENDPOINT=https://api.example.com/v1

# ============================================================================
# Production Settings (uncomment when using real Stack Auth)
# ============================================================================

# Stack Auth configuration (for production use)
# STACK_AUTH_API_URL=https://your-stack-auth-instance.com
# STACK_AUTH_PROJECT_ID=your-project-id
# STACK_AUTH_SECRET_KEY=your-secret-key

# Database URL (for production with PostgreSQL provider)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/gliam
