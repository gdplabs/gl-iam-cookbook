# =============================================================================
# RBAC Showcase - Multi-Provider Configuration
# =============================================================================
# This example supports both Keycloak and StackAuth providers.
# Set PROVIDER_TYPE to choose which provider to use.

# Provider Selection: "keycloak" or "stackauth"
PROVIDER_TYPE=keycloak

# =============================================================================
# Keycloak Configuration (when PROVIDER_TYPE=keycloak)
# =============================================================================
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=gl-iam-demo
KEYCLOAK_CLIENT_ID=glchat-backend
KEYCLOAK_CLIENT_SECRET=glchat-backend-secret

# =============================================================================
# Stack Auth Configuration (when PROVIDER_TYPE=stackauth)
# =============================================================================
STACKAUTH_BASE_URL=http://localhost:8102
STACKAUTH_PROJECT_ID=your-project-id
STACKAUTH_PUBLISHABLE_CLIENT_KEY=pk_your_publishable_key
STACKAUTH_SECRET_SERVER_KEY=ssk_your_secret_key
