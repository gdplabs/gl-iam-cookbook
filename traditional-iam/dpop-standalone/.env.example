# Shared HS256 secret used by BOTH the demo issuer (issue_token.py) and the
# resource server (main.py) to sign/verify the access token.
# In production this is your Authorization Server's signing key — the resource
# server only needs the verification key, never the client's DPoP private key.
SECRET_KEY=demo-secret-key-change-me-min-32-characters-long
