# --- Shared infrastructure ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:55432/gliam
REDIS_URL=redis://localhost:56379/0

# --- GLChat backend (port 8000) ---
GLCHAT_SECRET_KEY=glchat-jwt-secret-min-32-characters-long-change-me
# Generated by setup.sh (Fernet key — 32 url-safe base64 bytes)
GLCHAT_ENCRYPTION_KEY=
DEFAULT_ORGANIZATION_ID=glchat
SSO_TOKEN_TTL_SECONDS=60
HMAC_TIMESTAMP_TOLERANCE_SECONDS=60
NONCE_TTL_SECONDS=120
RATE_LIMIT_SSO_TOKEN=20/minute
RATE_LIMIT_SSO_AUTH=60/minute

# Bootstrap admin credentials (created by scripts/bootstrap_admin.py)
BOOTSTRAP_ADMIN_EMAIL=admin@glchat.example.com
BOOTSTRAP_ADMIN_PASSWORD=AdminPass123!

# --- Partner backend (port 8001) ---
PARTNER_ISSUER=trusted-partner
PARTNER_SESSION_SECRET=partner-session-cookie-secret-change-me
GLCHAT_BACKEND_URL=http://localhost:8000
# Populated by admin when partner is registered (scripts/bootstrap_partner.py writes these)
PARTNER_CONSUMER_KEY=
PARTNER_CONSUMER_SECRET=

# --- Frontend origins (for CSP + postMessage allowlist) ---
PARTNER_SITE_ORIGIN=http://localhost:3001
GLCHAT_ADMIN_ORIGIN=http://localhost:3002
GLCHAT_WIDGET_ORIGIN=http://localhost:3003
