# GL-IAM API Key Hierarchy Example Configuration
# Copy this file to .env and update the values

# PostgreSQL connection string (async driver)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gliam

# API key prefix (appears at the start of generated keys)
# Example: aip_abc123...
API_KEY_PREFIX=aip

# Database schema for GL-IAM tables
# Tables will be created in this schema
DB_SCHEMA=gl_iam

# Default organization ID for demo purposes
# In production, this would come from your application logic
DEFAULT_ORGANIZATION_ID=acme-123
